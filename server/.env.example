# =============================================
# SERVER - Environment Variables Example
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ----- Server Configuration -----
PORT=5000

# ----- Database (MongoDB) -----
# Local MongoDB
# MONGO_URI=mongodb://localhost:27017/traveldb

# MongoDB Atlas (Cloud) - Standard Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/traveldb?retryWrites=true&w=majority

# ----- Authentication -----
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=your_super_secret_jwt_key_here_replace_with_a_long_random_string

# ----- Weather API (OpenWeatherMap) -----
# Get your key at: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key

# ----- Flight API -----
# Get your key from your flight data provider
FLIGHT_API_KEY=your_flight_api_key

# ----- CORS / Frontend URL -----
# URL of your deployed frontend (for CORS)
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://your-frontend.vercel.app

# ----- Email (Gmail SMTP) -----
# Contributors: Use your own Gmail App Password for local OTP testing
#
# Steps to create Gmail App Password:
#   1. Go to your Google Account → https://myaccount.google.com
#   2. Navigate to: Security → How you sign in to Google → 2-Step Verification (enable it)
#   3. After enabling, go to: Security → App passwords ( search app password )
#   4. Select app: "Mail" → Select device: "Other" → type "TravelPlanner"
#   5. Copy the 16-character password shown → paste it in EMAIL_PASS below
#
# Official Guide: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
